generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  OPERATOR
  ADMIN
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  ARCHIVED
}

enum VehicleType {
  PICKUP
  BOX_TRUCK
  CARGO_VAN
  OTHER
}

enum BookingStatus {
  REQUESTED
  APPROVED
  REJECTED
  PAID
  CANCELLED
  COMPLETED
}

enum VerificationStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  NOT_READY
  PENDING_CAPTURE
  CAPTURED
}

enum NotificationState {
  PENDING
  SENT
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  role        Role      @default(CUSTOMER)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  listings    Listing[]
  bookings    Booking[]
}

model Listing {
  id          String        @id @default(cuid())
  ownerId     String
  title       String
  slug        String        @unique
  vehicleType VehicleType   @default(OTHER)
  description String        @db.Text
  reviewNotes String?       @db.Text
  photoUrls   String[]      @default([])
  boxSizeFeet Int?
  passengerCapacity Int?
  hasRamp     Boolean       @default(false)
  city        String
  state       String
  dailyRate   Int
  status      ListingStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookings    Booking[]
}

model Booking {
  id                 String             @id @default(cuid())
  listingId          String
  customerId         String
  startDate          DateTime
  endDate            DateTime
  totalAmount        Int
  status             BookingStatus      @default(REQUESTED)
  verificationStatus VerificationStatus @default(NOT_STARTED)
  paymentStatus      PaymentStatus      @default(NOT_READY)
  paymentCapturedAt  DateTime?
  paymentReference   String?
  customerNotificationKind String?
  customerNotificationState NotificationState @default(PENDING)
  customerNotificationSentAt DateTime?
  opsNotificationKind String?
  opsNotificationState NotificationState @default(PENDING)
  opsNotificationSentAt DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  listing            Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)
  customer           User               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  timelineEvents     BookingTimelineEvent[]
}

model BookingTimelineEvent {
  id        String   @id @default(cuid())
  bookingId String
  eventType String
  title     String
  detail    String   @db.Text
  actorRole String?
  actorName String?
  occurredAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, occurredAt])
}
